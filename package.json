{
  "name": "photos-api",
  "version": "1.0.0",
  "description": "Shared photo storage API for kylies.photos and kylieis.online",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply photos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply photos-db --remote"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.8.0",
    "wrangler": "^4.14.0"
  }
}
